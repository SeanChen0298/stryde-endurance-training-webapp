# ── Database ────────────────────────────────────────────────────────────────
# Neon serverless PostgreSQL — get from console.neon.tech
# Recommended region: AWS ap-southeast-1 (Singapore)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── Cache ────────────────────────────────────────────────────────────────────
# Upstash Redis — get from console.upstash.com
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# ── Security ─────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_generate_with_secrets_token_hex_32
JWT_EXPIRE_HOURS=168

# AES-256 key for encrypting Gemini API keys and Garmin tokens in DB
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GEMINI_ENCRYPTION_KEY=change_me_generate_with_secrets_token_hex_32

# ── Gemini (AI models) ────────────────────────────────────────────────────────
# NOTE: No GEMINI_API_KEY here — each user provides their own via Settings page.
# Users get a free key from: https://aistudio.google.com
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-2.5-flash-lite

# ── Strava OAuth ──────────────────────────────────────────────────────────────
# Register app at: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# In production: https://your-backend.railway.app/auth/strava/callback
# In development: http://localhost:8001/auth/strava/callback
STRAVA_WEBHOOK_CALLBACK_URL=http://localhost:8001/auth/strava/callback

# ── App URLs ──────────────────────────────────────────────────────────────────
# In production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3001
# Comma-separated list of allowed CORS origins
# In production: https://your-app.vercel.app
# In development: http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001

# ── App config ────────────────────────────────────────────────────────────────
ATHLETE_TIMEZONE=Asia/Kuala_Lumpur
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ── Google Calendar (Phase 3) ─────────────────────────────────────────────────
# Leave empty for now
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
