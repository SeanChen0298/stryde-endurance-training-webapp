# ── Database ────────────────────────────────────────────────────────────────
# Neon serverless PostgreSQL — get from console.neon.tech
# Recommended region: AWS ap-southeast-1 (Singapore)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/stryde?sslmode=require

# ── Cache ────────────────────────────────────────────────────────────────────
# Upstash Redis — get from console.upstash.com
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# ── Security ─────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_generate_with_secrets_token_hex_32
JWT_EXPIRE_HOURS=168

# AES-256 key for encrypting user Gemini API keys in DB
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GEMINI_ENCRYPTION_KEY=change_me_generate_with_secrets_token_hex_32

# ── Gemini (AI models) ────────────────────────────────────────────────────────
# NOTE: No GEMINI_API_KEY here — each user provides their own via Settings page.
# Users get a free key from: https://aistudio.google.com
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-2.5-flash-lite

# ── Strava OAuth ──────────────────────────────────────────────────────────────
# Register app at: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Webhook callback URL (must be public — use ngrok during development)
STRAVA_WEBHOOK_CALLBACK_URL=https://your-domain.com/webhooks/strava

# ── Garmin Connect Developer ──────────────────────────────────────────────────
# Apply at: https://developer.garmin.com/gc-developer-program/
# Leave empty during Phase 1 if approval pending — app degrades gracefully
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# ── Google Calendar ───────────────────────────────────────────────────────────
# Phase 3 feature — leave empty for now
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── App config ────────────────────────────────────────────────────────────────
ATHLETE_TIMEZONE=Asia/Kuala_Lumpur
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
